# Local development:
DATABASE_URL="file:./dev.db"
# Docker deployment:
# DATABASE_URL="file:/app/data/prompt-ide.db"

ADMIN_PASSWORD=change-me
MEMBER_PASSWORD=change-me-member
MINIMAX_API_KEY=replace-with-your-minimax-key
NODE_ENV=development

# Set HOSTNAME=0.0.0.0 for Docker deployment.
HOSTNAME=127.0.0.1
PORT=3000
NEXT_TELEMETRY_DISABLED=1

# Production required: must be base64 encoded and decode to 16, 24, or 32 bytes.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
